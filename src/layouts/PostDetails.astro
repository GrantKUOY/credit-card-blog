---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  dcardUrl,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const { Content } = await render(post);

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;

const postSlug = post.id;
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <h1
      transition:name={slugifyStr(title.replaceAll(".", "-"))}
      class="inline-block text-3xl sm:text-4xl"
    >
      {title}
    </h1>
    <div class="my-2 flex items-center gap-2">
      <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
      <span
        aria-hidden="true"
        class:list={[
          "max-sm:hidden",
          { hidden: !SITE.editPost.enabled || hideEditPost },
        ]}>|</span
      >
      <EditPost {hideEditPost} {post} class="max-sm:hidden" />
    </div>
    <article
      id="article"
      class="app-prose mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      <Content />
    </article>

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
    </ul>

    <BackToTopButton />

    <ShareLinks />

    <section
      id="public-comments"
      class="mt-10 border-t border-border pt-8"
      data-post-slug={postSlug}
    >
      <h2 class="text-xl font-semibold">留言</h2>
      <p class="mt-2 text-sm text-foreground/75">
        請勿留下卡號、ITIN、密碼等敏感資訊，留言會公開顯示
      </p>

      <div id="public-comments-status" class="mt-4 text-sm" role="status">
        載入留言中...
      </div>
      <div id="public-comments-list" class="mt-6 grid gap-4"></div>

      <form id="public-comments-form" class="mt-8 grid gap-4">
        <div class="grid gap-2">
          <label for="comment-name" class="text-sm font-medium">
            暱稱（必填）
          </label>
          <input
            id="comment-name"
            name="name"
            type="text"
            maxlength="50"
            required
            class="focus-outline rounded border border-border bg-background px-3 py-2"
          />
        </div>

        <div class="grid gap-2">
          <label for="comment-email" class="text-sm font-medium">
            Email（選填，不公開）
          </label>
          <input
            id="comment-email"
            name="email"
            type="email"
            autocomplete="email"
            class="focus-outline rounded border border-border bg-background px-3 py-2"
          />
        </div>

        <div class="grid gap-2">
          <label for="comment-message" class="text-sm font-medium">
            留言內容（必填）
          </label>
          <textarea
            id="comment-message"
            name="message"
            rows="5"
            maxlength="1000"
            required
            class="focus-outline rounded border border-border bg-background px-3 py-2"
          ></textarea>
        </div>

        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label for="comment-website">Website</label>
          <input
            id="comment-website"
            name="website"
            type="text"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <button
          type="submit"
          class="focus-outline w-fit rounded bg-accent px-4 py-2 font-medium text-background hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-60"
        >
          送出留言
        </button>

        <p id="public-comments-form-status" class="text-sm" role="status"></p>
      </form>
    </section>

    {
      dcardUrl && (
        <aside class="mt-6 rounded border border-border bg-muted/30 p-4 text-sm">
          有類似經驗或問題？歡迎到{" "}
          <a href={dcardUrl} target="_blank" rel="noopener noreferrer">
            Dcard 討論串
          </a>{" "}
          留言，我會盡量回覆。
        </aside>
      )
    }

    <hr class="my-6 border-dashed" />

    <!-- Previous/Next Post Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getPath(prevPost.id, prevPost.filePath)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>Previous Post</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getPath(nextPost.id, nextPost.filePath)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>Next Post</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      // Check if --file-name-offset custom property exists
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      // Determine the top positioning class
      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>

<script>
  type PublicComment = {
    name: string;
    message: string;
    created_at: string;
  };

  const commentsSection = document.querySelector("#public-comments");
  const commentsList = document.querySelector("#public-comments-list");
  const commentsStatus = document.querySelector("#public-comments-status");
  const commentsForm = document.querySelector("#public-comments-form");
  const commentsFormStatus = document.querySelector(
    "#public-comments-form-status"
  );
  const commentsSubmitButton = commentsForm?.querySelector(
    "button[type='submit']"
  );
  const postSlug = commentsSection?.getAttribute("data-post-slug") || "";

  function setCommentsStatus(message: string) {
    if (commentsStatus) commentsStatus.textContent = message;
  }

  function setCommentsFormStatus(message: string) {
    if (commentsFormStatus) commentsFormStatus.textContent = message;
  }

  function getRelativeTime(value: string) {
    const createdAt = new Date(value).getTime();
    const diffSeconds = Math.max(
      1,
      Math.floor((Date.now() - createdAt) / 1000)
    );
    const units: Array<[string, number]> = [
      ["年", 31536000],
      ["個月", 2592000],
      ["天", 86400],
      ["小時", 3600],
      ["分鐘", 60],
    ];

    for (const [label, seconds] of units) {
      const count = Math.floor(diffSeconds / seconds);
      if (count >= 1) return `${count} ${label}前`;
    }

    return "剛剛";
  }

  function renderComment(comment: PublicComment) {
    const article = document.createElement("article");
    article.className = "rounded border border-border bg-muted/20 p-4";

    const meta = document.createElement("div");
    meta.className = "text-sm text-foreground/70";
    meta.textContent = `${comment.name} · ${getRelativeTime(comment.created_at)}`;

    const message = document.createElement("p");
    message.className = "mt-3 whitespace-pre-wrap";
    message.textContent = comment.message;

    article.append(meta, message);
    return article;
  }

  function renderComments(comments: PublicComment[]) {
    if (!commentsList) return;

    commentsList.textContent = "";
    if (comments.length === 0) {
      setCommentsStatus("還沒有留言，來當第一個吧");
      return;
    }

    setCommentsStatus("");
    for (const comment of comments) {
      commentsList.append(renderComment(comment));
    }
  }

  async function loadPublicComments() {
    if (!postSlug) return;

    try {
      const response = await fetch(
        `/api/comments?slug=${encodeURIComponent(postSlug)}`
      );
      if (!response.ok) throw new Error("load failed");

      const data = (await response.json()) as { comments?: PublicComment[] };
      renderComments(data.comments || []);
    } catch {
      setCommentsStatus("目前無法載入留言。");
    }
  }

  commentsForm?.addEventListener("submit", async event => {
    event.preventDefault();

    if (
      !(commentsForm instanceof HTMLFormElement) ||
      !commentsSubmitButton ||
      !postSlug
    ) {
      return;
    }

    const formData = new FormData(commentsForm);
    const payload = Object.fromEntries(formData.entries());

    setCommentsFormStatus("");
    commentsSubmitButton.setAttribute("disabled", "true");

    try {
      const response = await fetch("/api/comments", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          post_slug: postSlug,
          ...payload,
        }),
      });

      const data = (await response.json()) as {
        status?: "published" | "pending";
        comment?: PublicComment;
      };
      if (!response.ok) throw new Error("submit failed");

      commentsForm.reset();
      if (data.status === "pending") {
        setCommentsFormStatus("留言含較多連結，將由站方確認後顯示");
        return;
      }

      if (data.comment && commentsList) {
        commentsList.append(renderComment(data.comment));
        setCommentsStatus("");
      }
      setCommentsFormStatus("留言已送出。");
    } catch {
      setCommentsFormStatus("目前無法送出留言，請稍後再試。");
    } finally {
      commentsSubmitButton.removeAttribute("disabled");
    }
  });

  loadPublicComments();
</script>
