---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout
  title={`聯絡我 | ${SITE.title}`}
  description="聯絡 Grant，回報文章更正、分享美國信用卡與旅遊點數經驗，或提出讀者問題。"
>
  <Header />
  <main id="main-content" class="app-layout">
    <section class="app-prose mb-28 max-w-app">
      <h1 class="text-2xl tracking-wider sm:text-3xl">聯絡我</h1>
      <p>
        想回報文章更正、分享申卡經驗，或有美國信用卡、ITIN、銀行開戶、旅遊點數相關問題，可以用這個表單傳訊息給我。
      </p>
      <p>請勿傳送完整卡號、ITIN、護照、銀行密碼或一次性驗證碼等敏感資訊。</p>

      <form
        id="contact-form"
        action="/api/contact"
        method="post"
        class="not-prose mt-8 grid gap-5"
      >
        <div class="grid gap-2">
          <label for="nickname" class="text-sm font-medium">暱稱（選填）</label>
          <input
            id="nickname"
            name="nickname"
            type="text"
            autocomplete="name"
            class="focus-outline rounded border border-border bg-background px-3 py-2"
          />
        </div>

        <div class="grid gap-2">
          <label for="email" class="text-sm font-medium">Email（必填）</label>
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            required
            class="focus-outline rounded border border-border bg-background px-3 py-2"
          />
        </div>

        <div class="grid gap-2">
          <label for="category" class="text-sm font-medium">分類</label>
          <select
            id="category"
            name="category"
            required
            class="focus-outline rounded border border-border bg-background px-3 py-2"
          >
            <option value="">請選擇分類</option>
            <option>美國信用卡申請</option>
            <option>ITIN・銀行開戶</option>
            <option>旅遊點數</option>
            <option>租車險理賠</option>
            <option>內容更正</option>
            <option>其他</option>
          </select>
        </div>

        <div class="grid gap-2">
          <label for="message" class="text-sm font-medium"
            >訊息內容（必填）</label
          >
          <textarea
            id="message"
            name="message"
            required
            rows="8"
            class="focus-outline rounded border border-border bg-background px-3 py-2"
          ></textarea>
        </div>

        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label for="hp_check">Leave this field blank</label>
          <input
            id="hp_check"
            name="hp_check"
            type="text"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <button
          type="submit"
          class="focus-outline w-fit rounded bg-accent px-5 py-2 font-medium text-background hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-60"
        >
          送出訊息
        </button>

        <p id="contact-status" class="text-sm" role="status" aria-live="polite">
        </p>
      </form>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const form = document.querySelector("#contact-form");
  const status = document.querySelector("#contact-status");
  const submitButton = form?.querySelector("button[type='submit']");

  form?.addEventListener("submit", async event => {
    event.preventDefault();

    if (!(form instanceof HTMLFormElement) || !status || !submitButton) return;

    status.textContent = "";
    submitButton.setAttribute("disabled", "true");

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const response = await fetch(form.action, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (!response.ok) throw new Error("送出失敗");

      form.reset();
      status.textContent =
        "已收到你的訊息，我會視時間回覆。請勿傳送完整卡號、ITIN、護照或銀行密碼等敏感資訊。";
    } catch {
      status.textContent = "目前無法送出訊息，請稍後再試。";
    } finally {
      submitButton.removeAttribute("disabled");
    }
  });
</script>
